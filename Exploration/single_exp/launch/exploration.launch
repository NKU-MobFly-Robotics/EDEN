<launch>
  <arg name="map" default="factory"/>

    <node name="single_exp_demo" pkg="single_exp" type="single_exp_node" output="screen">
        <rosparam command="load" file="$(find block_map_lite)/color/Paranoid.yaml" />
        <rosparam command="load" file="$(find single_exp)/resource/single_exp_sim_$(arg map)_lite_low_pad.yaml" />
        <rosparam command="load" file="$(find block_map_lite)/color/color_id.yaml" />
        <!-- <remap from="/depth" to="/firefly/vi_sensor/camera_depth/depth/disparity"/>
        <remap from="/odom" to="/firefly/ground_truth/odometry"/>
        <remap from="/vi_odom" to="/firefly/vi_sensor/ground_truth/odometry"/> -->
        <!-- <remap from="/block_map/caminfo" to="/firefly/vi_sensor/camera_depth/depth/camera_info"/> -->

        <remap from="/odom" to="/uav_simulator/odometry"/>
        <remap from="/vi_odom" to="/quad0_pcl_render_node/lidarOdometry"/>
        <remap from="/depth" to="/uav_simulator/depth_image"/>
        <remap from="/block_map/caminfo" to="/map_render_node/camera_info"/>
        <remap from="/pointcloud" to="/quad0_pcl_render_node/cloud"/>

    </node>

    <node name="traj_exc_node" pkg="traj_exc" type="traj_exc_node" output="screen">
        <rosparam command="load" file="$(find single_exp)/resource/single_exp_sim_$(arg map)_lite_low_pad.yaml" />
        <!-- <remap from="/odom" to="/firefly/ground_truth/odometry"/> -->
        <remap from="/trajectory_cmd" to="/single_exp_demo/Planner/Traj"/>
        <remap from="/sensor/ready" to="/single_exp_demo/sensor/ready"/>

        <remap from="/odom" to="/uav_simulator/odometry"/>

    </node>

    <!-- <include file="$(find single_exp)/launch/rotors_sim.launch">
        <arg name="world" value="octa_maze" />
        <arg name="gui" value="true" />
        <arg name="waypoint_x" value="0.0" />
        <arg name="waypoint_y" value="0.0" />
        <arg name="waypoint_z" value="1.0" />
        <arg name="odom_topic" value="/ground_truth/odometry" />
    </include> -->

    <include file="$(find single_exp)/launch/lite_sim.launch">
        <arg name="map_name" value="$(arg map)" />
        <!-- <arg name="gui" value="true" />
        <arg name="waypoint_x" value="0.0" />
        <arg name="waypoint_y" value="0.0" />
        <arg name="waypoint_z" value="1.0" />
        <arg name="odom_topic" value="/ground_truth/odometry" /> -->
    </include>
    <node name="map_pcl_node" pkg="map_visualization" type="map_pcl_node" output="screen">
        <remap from="/makers" to="/single_exp_demo/block_map/voxvis"/>
        <param name="MinZ" value="-0.2" />
        <param name="MaxZ" value="10.0" />
    </node>


    <!-- <node name="traj_gain_test" pkg="ato_test" type="traj_vel_vis" output="screen">
        <param name="VelMax" value="2.0"/>
        <remap from="odomshow" to="/uav_simulator/odometry"/>
    </node> -->

    <node name="rvizvisualisation" pkg="rviz" type="rviz" output="screen" args="-d $(find single_exp)/rviz/single_exp_demo_m_lite.rviz" />


    <!-- <node pkg="rosbag" type="record" name="bag_record" args="
        /uav_simulator/odometry
        /quad0_pcl_render_node/lidarOdometry
        /quad0_pcl_render_node/cloud
        -o /home/charliedog/rosprojects/EDEN_LiDAR/bags/pro.bag"/> -->
</launch>